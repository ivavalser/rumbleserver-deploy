# ============================================
# RUMBLE SERVER - Environment Configuration
# ============================================
# Operator bundle: cp env.example .env && nano .env

# ============================================
# DJANGO SETTINGS
# ============================================

# Режим отладки (False для продакшна!)
DEBUG=False

# Секретный ключ Django (будет сгенерирован автоматически при первом деплое, если не указан)
# Можно сгенерировать: python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'
SECRET_KEY=your-secret-key-here-generate-with-django

# Разрешенные хосты (через запятую, без пробелов)
# Для продакшна: yourdomain.com,www.yourdomain.com
# Для локальной разработки: localhost,127.0.0.1
ALLOWED_HOSTS=localhost,127.0.0.1

# ============================================
# DATABASE (PostgreSQL)
# ============================================
# При использовании Docker Compose:
#   - DB_HOST должен быть "db" (имя сервиса в docker-compose.yml)
#   - Остальные значения должны совпадать с POSTGRES_* в docker-compose.yml
# При использовании внешней БД:
#   - Укажи реальный хост и порт

DB_NAME=rumbleserver_db
DB_USER=rumbleserver_user
DB_PASS=change_this_to_strong_password
DB_HOST=db
DB_PORT=5432

# ============================================
# REDIS
# ============================================
# При использовании Docker Compose:
#   - REDIS_HOST должен быть "redis" (имя сервиса)
#   - REDIS_PASSWORD должен совпадать с паролем в docker-compose.yml
# При использовании внешнего Redis:
#   - Укажи реальный хост и порт

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change_this_to_strong_redis_password
REDIS_URL=redis://:change_this_to_strong_redis_password@redis:6379/0

# ============================================
# AWS S3 (для хранения файлов)
# ============================================
# Нужно создать S3 bucket и IAM пользователя с правами на запись
# 1. Создай bucket в AWS Console
# 2. Создай IAM пользователя с политикой доступа к bucket
# 3. Создай Access Key для этого пользователя
# 4. Заполни данные ниже

AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_STORAGE_BUCKET_NAME=your-bucket-name
AWS_S3_REGION_NAME=eu-north-1
AWS_S3_ENDPOINT_URL=https://s3.eu-north-1.amazonaws.com

# Пример для других регионов:
# eu-west-1: https://s3.eu-west-1.amazonaws.com
# us-east-1: https://s3.us-east-1.amazonaws.com
